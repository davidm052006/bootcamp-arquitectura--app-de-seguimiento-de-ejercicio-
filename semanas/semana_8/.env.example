PORT=3000
NODE_ENV=development

# JWT — OBLIGATORIO cambiar en producción (mínimo 32 caracteres)
JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres-aqui
JWT_EXPIRES_IN=15m

# bcrypt — más rounds = más seguro pero más lento (10-12 para producción)
BCRYPT_ROUNDS=10

# CORS — orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Base de datos (si usas PostgreSQL)
DATABASE_URL=postgres://fitwell:fitwell123@localhost:5432/fitwell_dev
