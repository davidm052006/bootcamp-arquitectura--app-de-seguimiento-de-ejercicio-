# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copia este archivo a .env y ajusta los valores
#
# NUNCA subas .env al repositorio (está en .gitignore)
# Este archivo SÍ va al repo — muestra qué variables se necesitan
# ─────────────────────────────────────────────────────────────────────────────

# Puerto de la API
PORT=3000

# Entorno: development | production
NODE_ENV=development

# Usar PostgreSQL (true) o InMemory (false)
USE_POSTGRES=true

# PostgreSQL
POSTGRES_USER=fitwell
POSTGRES_PASSWORD=fitwell123
POSTGRES_DB=fitwell_dev

# URL completa de conexión (construida con las variables anteriores)
DATABASE_URL=postgres://fitwell:fitwell123@db:5432/fitwell_dev

# pgAdmin (solo desarrollo)
PGADMIN_EMAIL=admin@fitwell.com
PGADMIN_PASSWORD=admin123

# Versión de la app
APP_VERSION=4.0.0
